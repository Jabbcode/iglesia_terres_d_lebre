# Database (Supabase)
# IMPORTANTE: Para producción en Vercel, usar puerto 6543 (Transaction Mode) con pgBouncer
# Esto evita el error "max clients reached" en entornos serverless
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
